    if(this.isOpen){
      setTimeout(()=>document.getElementById('chatWidgetInput').focus(), 200);
    }
  },

  quickAsk(question){
    document.getElementById('chatWidgetInput').value = question;
    this.send();
  },

  appendMessage(role, text){
    const body = document.getElementById('chatWidgetBody');
    const div = document.createElement('div');
    div.className = 'cw-msg ' + (role==='user' ? 'cw-user' : 'cw-bot');
    div.textContent = text;
    body.appendChild(div);
    body.scrollTop = body.scrollHeight;
    return div;
  },

  showTyping(){
    const body = document.getElementById('chatWidgetBody');
    const div = document.createElement('div');
    div.className = 'cw-msg cw-bot cw-typing';
    div.id = 'cwTypingIndicator';
    div.innerHTML = '<span></span><span></span><span></span>';
    body.appendChild(div);
    body.scrollTop = body.scrollHeight;
  },

  hideTyping(){
    const el = document.getElementById('cwTypingIndicator');
    if(el) el.remove();
  },

  // ⚠️ এখানে Cloudflare Worker-এর URL বসাতে হবে — Worker ডিপ্লয় করার পর যে URL পাবে
  // (যেমন: https://golapi-chat-proxy.তোমার-অ্যাকাউন্ট.workers.dev), সেটা এখানে বসাও।
  // worker.js ফাইলের উপরের কমেন্টে সম্পূর্ণ ডিপ্লয় গাইড আছে।
  workerUrl: 'https://golapi-chat-proxy.studiomt46.workers.dev',

  async send(){
    const input = document.getElementById('chatWidgetInput');
    const message = input.value.trim();
    if(!message) return;
    input.value = '';

    this.appendMessage('user', message);
    this.history.push({role:'user', content: message});
    this.showTyping();

    // worker.js ডিপ্লয় না করা পর্যন্ত workerUrl placeholder-এই থাকবে — সেক্ষেত্রে
    // সরাসরি স্পষ্ট মেসেজ দেখাই, যাতে "সংযোগে সমস্যা" বলে confusing fail না হয়।
    if(this.workerUrl.includes('YOUR-SUBDOMAIN')){
      this.hideTyping();
      this.appendMessage('bot', 'AI চ্যাট এখনো সেটআপ করা হয়নি — দোকান মালিককে worker.js ডিপ্লয় করতে হবে। এই মুহূর্তে golapishoponline.bd@gmail.com-এ মেসেজ দিন।');
      return;
    }

    try{
      const response = await fetch(this.workerUrl, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-6",
          max_tokens: 500,
          system: this.systemPrompt,
          messages: this.history,
        })
      });
      const data = await response.json();
      this.hideTyping();

      const replyText = (data.content || [])
        .filter(b => b.type === 'text')
        .map(b => b.text)
        .join('\n') || 'দুঃখিত, এই মুহূর্তে উত্তর দিতে পারছি না। আবার চেষ্টা করুন।';

      this.appendMessage('bot', replyText);
      this.history.push({role:'assistant', content: replyText});

      // কথোপকথন বেশি লম্বা হয়ে গেলে পুরনো অংশ ছেঁটে ফেলি, যাতে প্রতিটা request ছোট থাকে
      if(this.history.length > 20) this.history = this.history.slice(-20);
    }catch(e){
      this.hideTyping();
      devWarn('Chat widget error:', e.message);
      this.appendMessage('bot', 'সংযোগে সমস্যা হয়েছে। একটু পরে আবার চেষ্টা করুন, বা golapishoponline.bd@gmail.com-এ মেসেজ দিন।');
    }
  }
};

