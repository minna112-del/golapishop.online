const NotificationSystem = {
  VAPID_KEY: 'BPRxlznMoYaznW3dnf-OcB-MSplrzV6xA2bWWbPENH37-iAelbKjcwO5OXbGMirLpNu6w4XZBr7kwZLPepf9KRQ',
  WORKER_URL: null, // push notification পাঠানোর জন্য Cloudflare Worker URL — পরে সেট করতে হবে
  async setup(zone){
    if(!('Notification' in window) || !FB) return;
    const p = await Notification.requestPermission();
    if(p !== 'granted'){ toast('⚠ Notification permission দেওয়া হয়নি'); return; }
    try{
      const sw = await navigator.serviceWorker.register('/firebase-messaging-sw.js');
      await navigator.serviceWorker.ready;
      const {getMessaging, getToken, onMessage} = await import('https://www.gstatic.com/firebasejs/10.12.2/firebase-messaging.js');
      const msg = getMessaging(FB.auth.app);
      const token = await getToken(msg, {vapidKey: this.VAPID_KEY, serviceWorkerRegistration: sw});
      if(!token) return;
      await FB.setDoc(FB.doc(FB.db, 'setting', 'notification_tokens'), {[zone]: token}, {merge: true});
      onMessage(msg, payload => {
        toast('🔔 ' + (payload.notification?.body || 'নতুন অর্ডার এসেছে'));
        if(ZoneManagerDash.currentZone) ZoneManagerDash.render();
      });
      navigator.serviceWorker.addEventListener('message', e => {
        if(e.data?.type === 'OPEN_ZM'){
          Router.go('zone-manager');
          if(ZoneManagerDash.currentZone) ZoneManagerDash.render();
        }
      });
      toast('✅ নটিফিকেশন চালু হয়েছে');
    }catch(e){ devWarn('NS error:', e.message); }
  },
  async send(orderData){
    if(!FB || !this.WORKER_URL) return;
    try{
      const snap = await FB.getDoc(FB.doc(FB.db, 'setting', 'notification_tokens'));
      if(!snap.exists()) return;
      const token = snap.data()[orderData.branchZone];
      if(!token) return;
      const zl = orderData.branchZone === 'noakhali_sadar' ? 'নোয়াখালী সদর' : 'বেগমগঞ্জ';
      await fetch(this.WORKER_URL, {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({
          token,
          title: `🌹 নতুন অর্ডার — ${zl}`,
          body: `${orderData.customerName} | ${money(orderData.subtotal)} | ${orderData.orderNumber}`,
          data: {orderNumber: orderData.orderNumber, branchZone: orderData.branchZone}
        })
      });
    }catch(e){ devWarn('NS send error:', e.message); }
  }
};


