      if(this.mode==='add'){
        // "দুই জোনেই" সিলেক্ট করলে প্রতিটা জোনের জন্য আলাদা প্রোডাক্ট ডকুমেন্ট তৈরি হয় —
        // কারণ প্রতিটা শাখার স্টক/বিক্রি আলাদাভাবে ট্র্যাক হওয়া উচিত (Zone Manager সিস্টেমের
        // সাথে সামঞ্জস্য রেখে)। দুটো ডকুমেন্ট একই groupId শেয়ার করে, যাতে ভবিষ্যতে
        // চাইলে "এই প্রোডাক্ট সব শাখায় একসাথে এডিট করুন" এর মতো ফিচার বানানো সহজ হয়।
        const groupId = selectedZones.length>1 ? `${Date.now()}` : null;
        for(const zone of selectedZones){
          const productData = { ...baseProductData, zone, createdAt: FB.serverTimestamp(), rating:'৫.০', reviews:0, sold:0, fastDelivery:true };
          if(groupId) productData.groupId = groupId;
          await FB.addDoc(FB.collection(FB.db,'products'), productData);
        }
        msgEl.textContent = selectedZones.length>1
          ? '✓ প্রোডাক্ট দুই শাখাতেই যুক্ত হয়েছে'
          : '✓ প্রোডাক্ট সফলভাবে যুক্ত হয়েছে';
        msgEl.className='form-msg ok';
      } else {
        // এডিট মোডে সবসময় একটাই জোন থাকে (চেকবক্স লক করা থাকে openEdit-এ), তাই শুধু সেই একটা ফিল্ড পাঠাই
        const productData = { ...baseProductData, zone: selectedZones[0] };
        await FB.updateDoc(FB.doc(FB.db,'products',this.editId), productData);
        msgEl.textContent = '✓ প্রোডাক্ট আপডেট হয়েছে'; msgEl.className='form-msg ok';
      }

      await ProductStore.refreshAndRerender();
      if(ZoneManagerDash.currentZone){ ZoneManagerDash.render(); }
      else { AdminDash.renderProductsTable(); document.getElementById('aStatProducts').textContent = String(ALL_PRODUCTS.length); }
      setTimeout(()=>this.close(), 1000);
    }catch(e){
      msgEl.textContent = 'সমস্যা হয়েছে: ' + e.message; msgEl.className='form-msg err';
    }finally{
      btn.textContent = originalText; btn.disabled = false;
    }
  }
};

