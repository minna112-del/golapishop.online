/* ---------- Wishlist (simple local) ---------- */
const Wishlist = {
  items: JSON.parse(localStorage.getItem('golapi_wishlist')||'[]'),
  async toggle(id){
    const i = this.items.indexOf(id);
    if(i>=0){ this.items.splice(i,1); toast('উইশলিস্ট থেকে মুছে ফেলা হয়েছে'); }
    else { this.items.push(id); toast('❤️ উইশলিস্টে যুক্ত হয়েছে'); }
    localStorage.setItem('golapi_wishlist', JSON.stringify(this.items));

    // লগইন করা থাকলে Firestore-এও সিঙ্ক করি, যাতে অন্য ডিভাইসেও উইশলিস্ট দেখা যায়
    if(FB && Auth.currentUser){
      try{
        await FB.setDoc(
          FB.doc(FB.db,'users',Auth.currentUser.uid),
          { wishlist: this.items },
          { merge: true }
        );
      }catch(e){ devWarn('Wishlist sync failed:', e.message); }
    }
  },
  async loadFromFirestore(){
    if(!FB || !Auth.currentUser) return;
    try{
      const snap = await FB.getDoc(FB.doc(FB.db,'users',Auth.currentUser.uid));
      if(snap.exists() && snap.data().wishlist){
        this.items = snap.data().wishlist;
        localStorage.setItem('golapi_wishlist', JSON.stringify(this.items));
      }
    }catch(e){ devWarn('Wishlist load failed:', e.message); }
  }
};

